# ============================================================
# Jarvis — Personal AI Infrastructure
# Environment configuration template
# ============================================================
# Copy this file to `.env` and fill in your real values.
# NEVER commit a real `.env` file — it is gitignored on purpose.
# Copia questo file in `.env` e inserisci i tuoi valori reali.
# Non committare MAI un file `.env` reale — è gitignored di proposito.
#
# Pydantic Settings reads variables prefixed with JARVIS_*.
# Pydantic Settings legge le variabili che iniziano con JARVIS_*.
# ============================================================

# -------------------- General --------------------
JARVIS_ENVIRONMENT=development     # development | staging | test | production
JARVIS_DOMAIN=jarvis.local
JARVIS_PUBLIC_URL=http://localhost:8080
JARVIS_LOG_LEVEL=info              # debug | info | warning | error

# -------------------- Server --------------------
JARVIS_SERVER_HOST=0.0.0.0
JARVIS_SERVER_PORT=8080
JARVIS_SERVER_SECRET_KEY=replace-me-with-a-long-random-string
JARVIS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
JARVIS_CORS_ALLOW_CREDENTIALS=true

# -------------------- Host port mapping (docker compose) --------------------
# Override these if a port is already busy on your machine.
# Sovrascrivi se una porta è già occupata sul tuo sistema.
JARVIS_HOST_PORT=8080
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
QDRANT_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334

# -------------------- Database --------------------
# Async drivers shipped: postgresql+psycopg (psycopg3 async), sqlite+aiosqlite
JARVIS_DATABASE_URL=postgresql+psycopg://jarvis:jarvis@localhost:5432/jarvis
JARVIS_REDIS_URL=redis://localhost:6379/0

# Compose-only credentials (consumed by the postgres image)
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis
POSTGRES_DB=jarvis

# -------------------- Identity / JWT --------------------
# Leave empty in development: the server auto-generates an ephemeral ES256
# keypair at startup. In production both keys are required.
# Lascia vuoto in dev: il server genera una keypair ES256 ephemera.
# In produzione ambedue obbligatorie.
JARVIS_JWT_PRIVATE_KEY_PEM=
JARVIS_JWT_PUBLIC_KEY_PEM=
JARVIS_JWT_ACCESS_TTL_SECONDS=900       # 15 min
JARVIS_JWT_REFRESH_TTL_SECONDS=2592000  # 30 d
JARVIS_MFA_CHALLENGE_TTL_SECONDS=300
JARVIS_MFA_EMAIL_OTP_LENGTH=6

# -------------------- Vector store --------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# -------------------- LLM providers (optional) --------------------
# Set only the providers you actually use. Leave the others empty.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# Local Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Default model routing (small / medium / large)
JARVIS_MODEL_SMALL=ollama/llama3.2:1b
JARVIS_MODEL_MEDIUM=ollama/llama3.1:8b
JARVIS_MODEL_LARGE=anthropic/claude-haiku-4-5-20251001

# -------------------- Memory backend (M2+) --------------------
MEM0_API_KEY=
ZEP_API_KEY=
MEMORY_BACKEND=local              # local | mem0 | zep | letta

# -------------------- Voice / STT / TTS (M2+) --------------------
PICOVOICE_ACCESS_KEY=
WHISPER_MODEL=tiny.en             # tiny.en | base.en | small.en | medium.en
PIPER_VOICE=en_US-amy-medium

# -------------------- Web scraping (M3+) --------------------
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=               # leave empty for cloud, set for self-hosted
JINA_API_KEY=

# -------------------- Wearables / Health (M4+) --------------------
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=

# FHIR server (HAPI FHIR)
FHIR_SERVER_URL=http://localhost:8081/fhir

# -------------------- AR / VR / Holographic (M7+) --------------------
FRAME_DEVICE_ID=                  # Brilliant Labs Frame
MENTRAOS_API_KEY=
LOOKING_GLASS_BRIDGE_URL=http://localhost:33333

# -------------------- Smart home / IoT (optional) --------------------
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# -------------------- Telemetry / Observability --------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=jarvis
