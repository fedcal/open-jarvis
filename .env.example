# ============================================================
# Jarvis — Personal AI Infrastructure
# Environment configuration template
# ============================================================
# Copy this file to `.env` and fill in your real values.
# NEVER commit a real `.env` file — it is gitignored on purpose.
# Copia questo file in `.env` e inserisci i tuoi valori reali.
# Non committare MAI un file `.env` reale — è gitignored di proposito.
# ============================================================

# -------------------- General --------------------
JARVIS_ENV=development          # development | staging | production
JARVIS_DOMAIN=jarvis.local
JARVIS_PUBLIC_URL=http://localhost:8080
JARVIS_LOG_LEVEL=info           # debug | info | warning | error

# -------------------- Server --------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_SECRET_KEY=replace-me-with-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# -------------------- Database --------------------
DATABASE_URL=postgresql://jarvis:jarvis@localhost:5432/jarvis
REDIS_URL=redis://localhost:6379/0

# -------------------- Vector store --------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
CHROMA_HOST=http://localhost:8000

# -------------------- LLM providers --------------------
# Set only the providers you actually use. Leave the others empty.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# Local Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Default model routing (small / medium / large)
JARVIS_MODEL_SMALL=ollama/llama3.2:1b
JARVIS_MODEL_MEDIUM=ollama/llama3.1:8b
JARVIS_MODEL_LARGE=anthropic/claude-sonnet-4-6

# -------------------- Memory --------------------
MEM0_API_KEY=
ZEP_API_KEY=
MEMORY_BACKEND=mem0             # mem0 | zep | letta | local

# -------------------- Voice / STT / TTS --------------------
PICOVOICE_ACCESS_KEY=
WHISPER_MODEL=tiny.en           # tiny.en | base.en | small.en | medium.en
PIPER_VOICE=en_US-amy-medium

# -------------------- Web scraping --------------------
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=             # leave empty for cloud, set for self-hosted
JINA_API_KEY=

# -------------------- Wearables / Health --------------------
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=

# FHIR server (HAPI FHIR)
FHIR_SERVER_URL=http://localhost:8081/fhir

# -------------------- AR / VR / Holographic --------------------
FRAME_DEVICE_ID=                # Brilliant Labs Frame
MENTRAOS_API_KEY=
LOOKING_GLASS_BRIDGE_URL=http://localhost:33333

# -------------------- Smart home / IoT (optional) --------------------
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# -------------------- Auth / OAuth --------------------
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# -------------------- Telemetry / Observability --------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=jarvis
